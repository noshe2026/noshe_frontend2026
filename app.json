{
  "expo": {
    "name": "NOSHE 2026",
    "slug": "noshe-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/logo-1.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D74C8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.noshe2026.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo-1.png",
        "backgroundColor": "#004EA8"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NOSHE 2026 to scan attendee QR codes for admin check-in."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "33aa4120-a431-43e4-8b2b-cc0e0ccd8b3d"
      }
    }
  }
}
